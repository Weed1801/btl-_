<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Lý Phòng Trọ</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar { box-shadow: 0 2px 4px rgba(0,0,0,.05); }
        .card { transition: transform 0.2s; }
        .card:hover { transform: translateY(-2px); }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" href="@Url.Action("Index", "Home")">
                    <i class="bi bi-building-check"></i> QLPhongTro
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Home")">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Index", "Room")">Danh sách phòng</a>
                        </li>
                        @if (Context.Session.GetString("Role") == "Landlord")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Create", "Room")">Đăng tin</a>
                            </li>
                        }
                        @if (Context.Session.GetString("Role") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "User")">Quản lý người dùng</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav">
                        @if (Context.Session.GetInt32("UserId") != null)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle"></i> Xin chào, @Context.Session.GetString("Username")
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="@Url.Action("Profile", "User")"><i class="bi bi-person-lines-fill me-2"></i>Trang cá nhân</a></li>
                                    @if (Context.Session.GetString("Role") == "Admin" || Context.Session.GetString("Role") == "Landlord")
                                    {
                                        <li><a class="dropdown-item" href="@Url.Action("Dashboard", "Home")"><i class="bi bi-speedometer2 me-2"></i>Thống kê</a></li>
                                    }
                                    <li><a class="dropdown-item" href="@Url.Action("Index", "RentalContract")"><i class="bi bi-file-text me-2"></i>Hợp đồng của tôi</a></li>
                                    @if (Context.Session.GetString("Role") == "Admin")
                                    {
                                        <li><a class="dropdown-item" href="@Url.Action("Index", "User")"><i class="bi bi-people me-2"></i>Quản lý người dùng</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="@Url.Action("Logout", "Auth")"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Login", "Auth")">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary ms-2 rounded-pill px-4" href="@Url.Action("Register", "Auth")">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-white border-top py-4 mt-5">
        <div class="container text-center text-muted">
            <p class="mb-0">&copy; 2026 - Hệ Thống Quản Lý Phòng Trọ - Developed by TS. Thái Thanh Tùng</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>