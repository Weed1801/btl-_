@{
    ViewData["Title"] = "Bảng Thống Kê";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 text-primary"><i class="bi bi-speedometer2"></i> Bảng Điều Khiển</h1>
        <span class="text-muted">Cập nhật: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-primary text-white">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2 opacity-75">Tổng số phòng</h6>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-house-door fs-1 me-3"></i>
                        <span class="fs-2 fw-bold">@ViewBag.TotalRooms</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-success text-white">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2 opacity-75">Hợp đồng hiệu lực</h6>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-file-earmark-check fs-1 me-3"></i>
                        <span class="fs-2 fw-bold">@ViewBag.ActiveContracts</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-warning text-dark">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2 opacity-75">Tổng hợp đồng</h6>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-files fs-1 me-3"></i>
                        <span class="fs-2 fw-bold">@ViewBag.TotalContracts</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100 bg-info text-white">
                <div class="card-body">
                    <h6 class="card-title text-uppercase mb-2 opacity-75">Doanh thu dự kiến</h6>
                    <div class="d-flex align-items-center">
                        <i class="bi bi-currency-dollar fs-1 me-3"></i>
                        <span class="fs-3 fw-bold">@string.Format("{0:N0}", ViewBag.TotalRevenue) đ</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions & Charts Placeholder -->
    <div class="row g-4">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">Hoạt động gần đây</h5>
                </div>
                <div class="card-body">
                    <p class="text-muted text-center py-5">Chưa có dữ liệu biểu đồ chi tiết.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="card-title mb-0">Thao tác nhanh</h5>
                </div>
                <div class="list-group list-group-flush">
                    <a href="@Url.Action("Create", "Room")" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                        <i class="bi bi-plus-circle text-primary me-3 fs-5"></i>
                        <div>
                            <div class="fw-bold">Đăng phòng mới</div>
                            <small class="text-muted">Tạo tin đăng cho thuê phòng</small>
                        </div>
                    </a>
                    <a href="@Url.Action("Index", "RentalContract")" class="list-group-item list-group-item-action d-flex align-items-center py-3">
                        <i class="bi bi-journal-text text-success me-3 fs-5"></i>
                        <div>
                            <div class="fw-bold">Quản lý hợp đồng</div>
                            <small class="text-muted">Xem và duyệt hợp đồng thuê</small>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>