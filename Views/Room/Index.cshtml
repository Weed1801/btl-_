@model IEnumerable<QuanLyChoThuePhongTro.Models.Room>

@{
    ViewData["Title"] = "Danh sách phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Danh Sách Phòng Trọ</h2>

<div class="row mt-4">
    @foreach (var room in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">@room.Title</h5>
                    <p class="card-text">
                        <strong>Giá:</strong> @room.Price.ToString("N0") VNĐ/tháng<br />
                        <strong>Vị trí:</strong> @room.Location<br />
                        <strong>Diện tích:</strong> @room.Area m²<br />
                        <strong>Phòng ngủ:</strong> @room.Bedrooms | <strong>Phòng tắm:</strong> @room.Bathrooms<br />
                        <strong>Trạng thái:</strong> <span class="badge bg-info">@room.Status</span>
                    </p>
                    <a href="@Url.Action("Details", new { id = room.Id })" class="btn btn-sm btn-primary">Xem chi tiết</a>
                    @if (ViewBag.UserId == room.OwnerId && ViewBag.UserRole == "Landlord")
                    {
                        <a href="@Url.Action("Edit", new { id = room.Id })" class="btn btn-sm btn-warning">Sửa</a>
                        <a href="@Url.Action("Delete", new { id = room.Id })" class="btn btn-sm btn-danger">Xóa</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
