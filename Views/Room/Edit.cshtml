@model QuanLyChoThuePhongTro.Models.Room

@{
    ViewData["Title"] = "Sửa phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var imageList = !string.IsNullOrEmpty(Model.ImageUrls)
        ? Model.ImageUrls.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList()
        : new List<string>();

    var createdDateStr = Model.CreatedDate.ToString("o");
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <h2>Chỉnh Sửa Phòng Trọ</h2>
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="OwnerId" value="@Model.OwnerId" />
            <input type="hidden" name="CreatedDate" value="@createdDateStr" />
            @* Giữ nguyên ảnh cũ qua hidden field *@
            <input type="hidden" name="existingImageUrls" value="@Model.ImageUrls" />

            <div class="mb-3">
                <label for="title" class="form-label">Tiêu đề:</label>
                <input type="text" class="form-control" id="title" name="title" value="@Model.Title" required />
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Mô tả:</label>
                <textarea class="form-control" id="description" name="description" rows="4">@Model.Description</textarea>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="price" class="form-label">Giá thuê (VNĐ/tháng):</label>
                        <input type="number" class="form-control" id="price" name="price" value="@Model.Price" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="area" class="form-label">Diện tích (m²):</label>
                        <input type="number" class="form-control" id="area" name="area" step="0.1" value="@Model.Area" required />
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="location" class="form-label">Địa chỉ:</label>
                <input type="text" class="form-control" id="location" name="location" value="@Model.Location" required />
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="district" class="form-label">Quận:</label>
                        <input type="text" class="form-control" id="district" name="district" value="@Model.District" required />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="ward" class="form-label">Phường:</label>
                        <input type="text" class="form-control" id="ward" name="ward" value="@Model.Ward" required />
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="bedrooms" class="form-label">Số phòng ngủ:</label>
                        <input type="number" class="form-control" id="bedrooms" name="bedrooms" value="@Model.Bedrooms" />
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="bathrooms" class="form-label">Số phòng tắm:</label>
                        <input type="number" class="form-control" id="bathrooms" name="bathrooms" value="@Model.Bathrooms" />
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <div class="form-check">
                    @if (Model.HasKitchen)
                    {
                        <input class="form-check-input" type="checkbox" id="hasKitchen" name="hasKitchen" checked />
                    }
                    else
                    {
                        <input class="form-check-input" type="checkbox" id="hasKitchen" name="hasKitchen" />
                    }
                    <label class="form-check-label" for="hasKitchen">Có bếp</label>
                </div>
                <div class="form-check">
                    @if (Model.HasWiFi)
                    {
                        <input class="form-check-input" type="checkbox" id="hasWiFi" name="hasWiFi" checked />
                    }
                    else
                    {
                        <input class="form-check-input" type="checkbox" id="hasWiFi" name="hasWiFi" />
                    }
                    <label class="form-check-label" for="hasWiFi">Có WiFi</label>
                </div>
                <div class="form-check">
                    @if (Model.HasAirConditioner)
                    {
                        <input class="form-check-input" type="checkbox" id="hasAirConditioner" name="hasAirConditioner" checked />
                    }
                    else
                    {
                        <input class="form-check-input" type="checkbox" id="hasAirConditioner" name="hasAirConditioner" />
                    }
                    <label class="form-check-label" for="hasAirConditioner">Có điều hòa</label>
                </div>
                <div class="form-check">
                    @if (Model.HasWashing)
                    {
                        <input class="form-check-input" type="checkbox" id="hasWashing" name="hasWashing" checked />
                    }
                    else
                    {
                        <input class="form-check-input" type="checkbox" id="hasWashing" name="hasWashing" />
                    }
                    <label class="form-check-label" for="hasWashing">Có máy giặt</label>
                </div>
            </div>
            <div class="mb-3">
                <label for="status" class="form-label">Trạng thái:</label>
                <select class="form-select" id="status" name="status">
                    @if (Model.Status == "Available")
                    {
                        <option value="Available" selected>Có sẵn</option>
                        <option value="Rented">Đã cho thuê</option>
                        <option value="Maintenance">Bảo trì</option>
                    }
                    else if (Model.Status == "Rented")
                    {
                        <option value="Available">Có sẵn</option>
                        <option value="Rented" selected>Đã cho thuê</option>
                        <option value="Maintenance">Bảo trì</option>
                    }
                    else
                    {
                        <option value="Available">Có sẵn</option>
                        <option value="Rented">Đã cho thuê</option>
                        <option value="Maintenance" selected>Bảo trì</option>
                    }
                </select>
            </div>

            @* Hiển thị ảnh hiện có với nút xóa từng ảnh *@
            @if (imageList.Count > 0)
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">📷 Ảnh hiện có (@imageList.Count ảnh):</label>
                    <div class="d-flex flex-wrap gap-2" id="existingImages">
                        @foreach (var img in imageList)
                        {
                            <div class="position-relative" data-img="@img">
                                <img src="@img" alt="Ảnh phòng"
                                     style="width:130px;height:97px;object-fit:cover;border-radius:8px;border:2px solid #dee2e6;" />
                                <button type="button"
                                        class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0"
                                        style="width:22px;height:22px;font-size:12px;line-height:1;border-radius:50%;"
                                        onclick="removeImage(this, '@img')"
                                        title="Xóa ảnh này">✕</button>
                            </div>
                        }
                    </div>
                </div>
            }

            @* Upload ảnh mới (nhiều ảnh) *@
            <div class="mb-4">
                <label class="form-label fw-bold">📷 Thêm ảnh mới:</label>
                <input type="file" class="form-control" name="roomImages" id="roomImages"
                       accept="image/jpeg,image/png,image/gif,image/webp" multiple />
                <div class="form-text text-muted">Có thể chọn nhiều ảnh cùng lúc. Ảnh mới sẽ được thêm vào ảnh hiện có.</div>
                <div id="imagePreview" class="d-flex flex-wrap gap-2 mt-2"></div>
            </div>

            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary">Hủy</a>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Preview ảnh mới chọn
        document.getElementById('roomImages').addEventListener('change', function () {
            const preview = document.getElementById('imagePreview');
            preview.innerHTML = '';
            Array.from(this.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = e => {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.cssText = 'width:130px;height:97px;object-fit:cover;border-radius:8px;border:2px solid #0d6efd;';
                    img.title = file.name;
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        });

        // Xóa ảnh cũ khỏi danh sách
        function removeImage(btn, imgUrl) {
            const wrapper = btn.closest('[data-img]');
            wrapper.remove();

            // Cập nhật hidden field existingImageUrls
            const hiddenField = document.querySelector('input[name="existingImageUrls"]');
            let urls = hiddenField.value.split(',').filter(u => u.trim() !== '' && u.trim() !== imgUrl.trim());
            hiddenField.value = urls.join(',');
        }
    </script>
}
