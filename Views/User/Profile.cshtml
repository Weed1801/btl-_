@model QuanLyChoThuePhongTro.Models.User

@{
    ViewData["Title"] = "Trang cá nhân";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white p-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-white rounded-circle p-3 text-primary me-3">
                            <i class="fas fa-user fa-3x"></i>
                        </div>
                        <div>
                            <h3 class="mb-0">@Model.FullName</h3>
                            <p class="mb-0 opacity-75">@@@Model.Username · <span class="badge bg-light text-primary">@Model.Role</span></p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Profile" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <h5 class="border-bottom pb-2 mb-4 text-primary">Thông tin cơ bản</h5>
                        
                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FullName" class="form-label fw-bold">Họ và tên</label>
                                <input asp-for="FullName" class="form-control" placeholder="Nhập họ tên đầy đủ" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold">Địa chỉ Email</label>
                                <input asp-for="Email" class="form-control" type="email" placeholder="email@example.com" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold">Số điện thoại</label>
                                <input asp-for="PhoneNumber" class="form-control" placeholder="Nhập số điện thoại" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày tham gia</label>
                                <input class="form-control" value="@Model.CreatedDate.ToString("dd/MM/yyyy")" disabled />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Address" class="form-label fw-bold">Địa chỉ</label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Nhập địa chỉ cư trú"></textarea>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Cập nhật thông tin
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
